# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAAA-your-token-here

# Telegram ID админов через запятую (свой ID можно узнать у @userinfobot)
ADMIN_IDS=123456789

# Опционально: ID приватного канала-архива (бот должен быть админом канала).
# Каждый загруженный файл будет копироваться туда как резервная копия.
# Оставь пустым, чтобы отключить.
ARCHIVE_CHANNEL_ID=

# Путь к файлу базы данных (метаданные: file_id, категории, права)
DATABASE_PATH=data/skhron.db
